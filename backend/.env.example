# ── Servidor ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/notifica-ai

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET=substitua_por_uma_string_longa_e_aleatoria

# ── E-mail (Gmail) ─────────────────────────────────────────
EMAIL_REMETENTE=seuemail@gmail.com
SENHA_APP=senha_de_app_do_gmail

# ── URLs ───────────────────────────────────────────────────
# URL pública do backend (usada em links de cancelamento de alerta)
BASE_URL=https://notifica-ai.onrender.com

# ── CORS ───────────────────────────────────────────────────
# Lista separada por vírgula das origens permitidas pelo CORS.
# Em produção inclua o domínio do seu frontend (ex.: Vercel).
CORS_ORIGINS=https://notifica-ai.vercel.app,http://localhost:5173
