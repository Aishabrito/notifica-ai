# ── Servidor ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── MongoDB ────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/notifica-ai

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET=substitua_por_uma_string_longa_e_aleatoria

# ── E-mail (Resend) ────────────────────────────────────────
# Crie uma conta gratuita em https://resend.com (3.000 e-mails/mês)
# e gere uma API Key no painel (resend.com/api-keys).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Endereço de envio verificado no Resend.
# Domínio notifica.dev.br já verificado — use qualquer prefixo abaixo:
#   noreply@notifica.dev.br  (padrão recomendado)
#   alerta@notifica.dev.br
#   contato@notifica.dev.br
EMAIL_REMETENTE=noreply@notifica.dev.br

# ── URLs ───────────────────────────────────────────────────
# URL pública do backend (usada em links de cancelamento de alerta)
BASE_URL=https://notifica.dev.br

# ── CORS ───────────────────────────────────────────────────
# Lista separada por vírgula das origens permitidas pelo CORS.
CORS_ORIGINS=https://notifica.dev.br,http://localhost:5173
